# Copy to .env in this folder (kawan/) and fill in. All vars use the KAWAN_ prefix (backend/app/config.py).
#
# DEV defaults (local SQLite, Vite proxy, SameSite=lax):
KAWAN_DATABASE_URL=sqlite+aiosqlite:///./kawan.db
KAWAN_FRONTEND_ORIGIN=http://localhost:5173
KAWAN_FRONTEND_POST_LOGIN_REDIRECT=http://localhost:5173/
KAWAN_APP_TZ=Asia/Kuala_Lumpur
# AI backend: 'stub' (deterministic, offline) or 'chutes' (real TEE inference).
# Local dev and CI use 'stub'; the demo/prod deploy sets this to 'chutes'.
KAWAN_AI_BACKEND=stub

# Chutes inference (OpenAI-compatible) + IdP/account API
KAWAN_CHUTES_INFERENCE_BASE_URL=https://llm.chutes.ai/v1
KAWAN_CHUTES_API_BASE_URL=https://api.chutes.ai
KAWAN_CHUTES_API_KEY=

# Sign in with Chutes (OAuth2 PKCE). Register the redirect_uri below on the cid_ app.
KAWAN_SIWC_CLIENT_ID=
KAWAN_SIWC_CLIENT_SECRET=
KAWAN_SIWC_APP_ID=
KAWAN_SIWC_REDIRECT_URI=http://localhost:5173/api/auth/siwc/callback
KAWAN_SIWC_SCOPES=openid profile chutes:invoke

# Secrets
# IMPORTANT (prod): KAWAN_SESSION_SECRET must be set to a fresh random value.
# KAWAN_FERNET_KEY must also be set explicitly in prod — encrypted SIWC tokens are bound
# to this key and will be unreadable after a restart if it changes. Never use the dev fallback.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KAWAN_SESSION_SECRET=dev-only-change-me
KAWAN_FERNET_KEY=

# Cross-origin cookies (only needed in prod — Vercel /ws connects directly to Render).
# In prod set both in Render env: KAWAN_COOKIE_SAMESITE=none + KAWAN_COOKIE_SECURE=true
# Dev defaults (lax / False) keep bun dev + uvicorn working with no extra config.
# KAWAN_COOKIE_SAMESITE=none
# KAWAN_COOKIE_SECURE=true

# Web Push (VAPID) — blank disables push; the delivery ladder falls back to timeline.
# Generate a keypair with: pip install py-vapid && vapid --gen
# This produces applicationServerKey (public, base64url) and private key.
# Place KAWAN_VAPID_PUBLIC_KEY + KAWAN_VAPID_PRIVATE_KEY in Render's env UI (never here).
# The public key is served by GET /api/push/vapid-public-key (no rebuild needed to rotate).
# Human ops step: generate + place in Render; client lights up automatically.
KAWAN_VAPID_PUBLIC_KEY=
KAWAN_VAPID_PRIVATE_KEY=
KAWAN_VAPID_SUBJECT=mailto:kawan@example.com

# Voice (TTS) — Piper neural TTS, local/demo only.
# Set to the directory containing <voice>.onnx + <voice>.onnx.json files.
# Run scripts/download_voices.sh to fetch the three persona voices locally.
# Leave blank → endpoint returns 204 No Content (frontend falls back to WebSpeech).
# Three voices used: en_US-lessac-medium (kawan), en_US-libritts-high (adik), en_GB-alba-medium (cik_maid)
KAWAN_PIPER_VOICES_DIR=

# Stake + win-back email (Resend). Blank → log-only outbox so the miss path still runs.
KAWAN_RESEND_API_KEY=
KAWAN_EMAIL_FROM=Kawan <kawan@example.com>

# ── PROD-ONLY placeholders (fill these in Render's env UI, not here) ─────────────────────────
#
# Database — use the Supabase Supavisor POOLER host (direct connection is IPv6-only on free tier).
# Recommended: session pooler port 5432 (no prepared-statement cache quirks).
# See kawan/backend/DEPLOY.md for transaction-pooler (6543) notes.
# KAWAN_DATABASE_URL=postgresql+asyncpg://<user>:<pwd>@<supabase-pooler-host>:5432/postgres
#
# CORS / redirects — fill once Vercel URL is known; update Render after Vercel deploy.
# KAWAN_FRONTEND_ORIGIN=https://<your-app>.vercel.app
# KAWAN_FRONTEND_POST_LOGIN_REDIRECT=https://<your-app>.vercel.app/
#
# SIWC callback — register this URL in the Chutes developer console alongside localhost.
# KAWAN_SIWC_REDIRECT_URI=https://<your-app>.vercel.app/api/auth/siwc/callback

# ── Frontend (Vercel env UI) ──────────────────────────────────────────────────────────────────
#
# Direct WebSocket URL — prod only; dev uses the Vite proxy (VITE_WS_URL should be UNSET in dev).
# VITE_WS_URL=wss://<your-render-app>.onrender.com/ws
#
# Leave VITE_USE_MOCK_AUTH unset (or false) in prod.
# VITE_USE_MOCK_AUTH=false
