# Repo-root ignores. App-specific patterns live in kawan/.gitignore.

# Artifacts
node_modules/
.codex

# OS / editor noise (can surface anywhere, e.g. docs/)
.DS_Store
Thumbs.db
.idea/

# Logs
*.log

# Env files — never commit secrets at any level
.env
.env.*

# Internal planning docs (kept local, excluded from the published repo)
docs/design-system.md
docs/kawan-spec.md
docs/task-list.md
docs/superpowers/
